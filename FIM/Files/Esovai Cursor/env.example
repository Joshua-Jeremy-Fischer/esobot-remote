# ── PFLICHT ───────────────────────────────────────────────────
ALLOWED_TOKEN=                        # openssl rand -base64 32
FRONTEND_ORIGIN=https://kamikimi.esovai.tech

# ── Provider ──────────────────────────────────────────────────
DEFAULT_PROVIDER=ollama
OLLAMA_MODEL=kimi-k2.5:cloud
OLLAMA_BASE_URL=http://ollama:11434/v1
OPENCODE_API_KEY=
OPENCODE_BASE_URL=https://opencode.ai/zen/go/v1
OPENCODE_MODEL=opencode-go/kimi-k2.5
NVIDIA_API_KEY=
GROQ_API_KEY=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
ENCRYPTION_KEY=                       # openssl rand -hex 32

# ── Eso Bot (Container + Backend-Proxy) ─────────────────────
# Gleicher Wert in beiden Services: backend proxied mit Authorization: Bearer …
AGENT_BASE_URL=http://eso-bot:3020
ESO_BOT_TOKEN=                        # Pflicht (openssl rand -base64 32), außer:
# ESO_BOT_INSECURE_NO_AUTH=true      # nur lokal: eso-bot ohne Bearer starten

# Folgende Werte nutzt docker-compose für den eso-bot-Service (Sandbox + Tools):
AGENT_PORT=3020
SANDBOX_ROOT=/workspace
LLM_BASE_URL=http://ollama:11434/v1
LLM_API_KEY=ollama
LLM_MODEL=kimi-k2.5:cloud
ALLOW_SHELL=false
ALLOW_WEB=true
ALLOW_FILES=true
ALLOW_GIT=false

# ── Server ────────────────────────────────────────────────────
PORT=3010
