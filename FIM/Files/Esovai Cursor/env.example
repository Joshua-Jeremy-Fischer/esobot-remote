# ── PFLICHT — Server startet ohne diese Werte NICHT ──────
ALLOWED_TOKEN=                        # openssl rand -base64 32
FRONTEND_ORIGIN=https://kamikimi.esovai.tech

# ── Provider (Standard) ───────────────────────────────────
DEFAULT_PROVIDER=opencode-go          # nvidia | opencode-go | ollama | github-copilot | groq

# ── OpenCode Go (Kimi K2.5 — Abo-basiert) ────────────────
OPENCODE_API_KEY=                     # sk-... von platform.opencode.ai
OPENCODE_BASE_URL=https://opencode.ai/zen/go/v1
OPENCODE_MODEL=opencode-go/kimi-k2.5

# ── Nvidia (Kimi K2 — Pay-as-you-go) ─────────────────────
NVIDIA_API_KEY=                       # nvapi-... von build.nvidia.com
NVIDIA_MODEL=moonshotai/kimi-k2-instruct-0905

# ── Ollama (lokal, kostenlos) ─────────────────────────────
OLLAMA_MODEL=llama3.1:8b
# OLLAMA_BASE_URL=http://ollama:11434/v1

# ── Groq (kostenloser Free Tier) ─────────────────────────
GROQ_API_KEY=                         # von console.groq.com
GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_BASE_URL=https://api.groq.com/openai/v1

# ── Anthropic (Claude) ────────────────────────────────────
ANTHROPIC_API_KEY=                    # sk-ant-... von console.anthropic.com
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# ── GitHub Copilot (OAuth — $10/Monat Abo) ───────────────
GITHUB_CLIENT_ID=                     # GitHub OAuth App → github.com/settings/developers
GITHUB_CLIENT_SECRET=                 # GitHub OAuth App Secret
COPILOT_MODEL=gpt-4o                  # gpt-4o | claude-sonnet-4-5 | gemini-1.5-pro
ENCRYPTION_KEY=                       # openssl rand -hex 32 (64 Hex-Zeichen für AES-256)

# ── kimi-agent (Tool-Calling, SQLite-Queue, Sandbox) ─────
AGENT_BEARER_TOKEN=                   # openssl rand -base64 32 (eigenes Secret)
AGENT_BASE_URL=http://kimi-agent:3020
AGENT_PORT=3020
# ALLOW_HTTP_TOOL=false               # true = Tool http_request erlauben (Vorsicht)
# ALLOW_WEB_SEARCH=false              # true = Web-Suche erlauben
# ALLOW_SHELL_EXEC=false              # true = Shell-Befehle in Sandbox erlauben
# AGENT_MAX_ITERATIONS=20
# AGENT_MAX_TOKENS=4096

# ── Server ────────────────────────────────────────────────
PORT=3010
